<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SistemaEmpresa.Views.Admin.UsuariosWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <!-- HEADER -->
        <Grid Background="#3B82F6" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Administración de Usuarios"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>

            <Button Content="Volver"
                    Click="Volver_Click"
                    Background="White"
                    Foreground="#3B82F6"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Margin="20,80,20,20" Spacing="15">

            <!-- FORMULARIO -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="txtNombre" PlaceholderText="Usuario" Width="150"/>
                <PasswordBox x:Name="txtPassword" PlaceholderText="Contraseña" Width="150"/>

                <ComboBox x:Name="cmbRol" Width="150"/>

                <Button Content="Crear"
                        Click="Crear_Click"
                        Background="#3B82F6"
                        Foreground="White"/>
            </StackPanel>

            <!-- LISTA -->
            <Border Background="White" CornerRadius="10" Padding="10">
                <ListView x:Name="listaUsuarios" Height="300"/>
            </Border>

            <Button Content="Desactivar Usuario"
                    Click="Desactivar_Click"
                    Background="#EF4444"
                    Foreground="White"/>

        </StackPanel>
    </Grid>
</Window>
