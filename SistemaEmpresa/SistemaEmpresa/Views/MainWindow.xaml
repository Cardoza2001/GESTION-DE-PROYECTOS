<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SistemaEmpresa.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <!-- 🔵 HEADER -->
        <Grid Background="#3B82F6" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Sistema Empresarial"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>
        </Grid>

        <!-- CONTENIDO -->
        <Grid Margin="0,60,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 🧭 MENÚ -->
            <StackPanel Background="#E5E7EB" Padding="12">

                <TextBlock Text="Menú"
                           FontWeight="Bold"
                           Foreground="Black"
                           Margin="0,0,0,15"/>

                <!-- BOTONES -->
                <Button x:Name="btnConsumibles"
                        Content="Consumibles"
                        Click="Consumibles_Click"
                        Margin="0,5"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        PointerEntered="MenuHover"
                        PointerExited="MenuLeave"/>

                <Button x:Name="btnHerramientas"
                        Content="Herramientas"
                        Click="Herramientas_Click"
                        Margin="0,5"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        PointerEntered="MenuHover"
                        PointerExited="MenuLeave"/>

                <Button x:Name="btnProyectos"
                        Content="Proyectos"
                        Click="Proyectos_Click"
                        Margin="0,5"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        PointerEntered="MenuHover"
                        PointerExited="MenuLeave"/>

                <Button x:Name="btnJefe"
                        Content="Panel del Jefe"
                        Click="Jefe_Click"
                        Margin="0,5"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        PointerEntered="MenuHover"
                        PointerExited="MenuLeave"/>

                <!-- 🔥 NUEVO BOTÓN ADMIN -->
                <Button x:Name="btnUsuarios"
                        Content="Usuarios"
                        Click="Usuarios_Click"
                        Margin="0,5"
                        Background="White"
                        Foreground="Black"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        PointerEntered="MenuHover"
                        PointerExited="MenuLeave"/>

                <Border Height="1" Background="#D1D5DB" Margin="10"/>

                <!-- LOGOUT -->
                <Button Content="Cerrar sesión"
                        Click="Logout_Click"
                        Margin="0,5"
                        Background="#EF4444"
                        Foreground="White"
                        CornerRadius="6"
                        Padding="10"/>
            </StackPanel>

            <!-- 📊 CONTENIDO -->
            <StackPanel Grid.Column="1" Padding="20" Spacing="15">

                <TextBlock x:Name="txtBienvenida"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="Black"/>

                <!-- TARJETAS -->
                <StackPanel Orientation="Horizontal" Spacing="15">

                    <Border Background="#E0F2FE" Padding="15" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Consumibles" Foreground="Black"/>
                            <TextBlock Text="0"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="Black"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#DCFCE7" Padding="15" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Herramientas" Foreground="Black"/>
                            <TextBlock Text="0"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="Black"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FEF3C7" Padding="15" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Proyectos" Foreground="Black"/>
                            <TextBlock Text="0"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="Black"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <TextBlock Text="Selecciona una opción del menú para comenzar."
                           Foreground="Gray"/>

            </StackPanel>
        </Grid>
    </Grid>
</Window>