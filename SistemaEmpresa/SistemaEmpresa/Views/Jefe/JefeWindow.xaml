<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SistemaEmpresa.Views.Jefe.JefeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <Grid Background="#3B82F6" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Sistema Empresarial"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>

            <Button Content="Volver"
                    Click="Volver_Click"
                    Background="White"
                    Foreground="#3B82F6"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Margin="20,80,20,20" Spacing="15">

            <TextBlock Text="Panel del Jefe"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Black"/>

            <TextBlock Text="Proyectos" FontWeight="Bold"/>

            <ListView x:Name="listaProyectos" Height="200"/>

            <Button Content="Aprobar Proyecto"
                    Click="Aprobar_Click"
                    Background="#3B82F6"
                    Foreground="White"/>

            <TextBlock Text="Transacciones" FontWeight="Bold"/>

            <ListView x:Name="listaTransacciones" Height="200"/>

        </StackPanel>
    </Grid>
</Window>