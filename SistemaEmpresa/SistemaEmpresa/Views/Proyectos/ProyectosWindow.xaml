<Window
    x:Class="SistemaEmpresa.Views.Proyectos.ProyectosWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="20" Spacing="10">

        <TextBlock Text="Gestión de Proyectos"
                   FontSize="22"
                   FontWeight="Bold"/>

        <TextBox x:Name="txtNombre"
                 PlaceholderText="Nombre del proyecto"/>

        <TextBox x:Name="txtCosto"
                 PlaceholderText="Costo estimado"/>

        <Button Content="Crear Proyecto"
                Click="Crear_Click"/>

        <ListView x:Name="lista"/>

    </StackPanel>
</Window>