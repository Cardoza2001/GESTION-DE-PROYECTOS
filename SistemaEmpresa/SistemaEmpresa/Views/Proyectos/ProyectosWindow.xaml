<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SistemaEmpresa.Views.Proyectos.ProyectosWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <Grid Background="#3B82F6" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Sistema Empresarial"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>

            <Button Content="Volver"
                    Click="Volver_Click"
                    Background="White"
                    Foreground="#3B82F6"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Margin="20,80,20,20" Spacing="15">

            <TextBlock Text="Gestión de Proyectos"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Black"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="txtNombre" PlaceholderText="Nombre" Width="220" Foreground="Black"/>
                <TextBox x:Name="txtCosto" PlaceholderText="Costo" Width="120" Foreground="Black"/>
                <Button Content="Crear" Click="Crear_Click"
                        Background="#3B82F6" Foreground="White"/>
            </StackPanel>

            <Border Background="White" CornerRadius="10" Padding="10">
                <ListView x:Name="lista" Height="300">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F9FAFB" Padding="10" Margin="5" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Nombre}" FontWeight="Bold" Foreground="Black"/>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Costo: " Foreground="Black"/>
                                        <TextBlock Text="{Binding CostoEstimado}" Foreground="Black"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Estado: " Foreground="Black"/>
                                        <TextBlock Text="{Binding Estado}" Foreground="Black"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>
            </Border>

        </StackPanel>
    </Grid>
</Window>