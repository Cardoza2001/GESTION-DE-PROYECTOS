<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SistemaEmpresa.Views.Herramientas.HerramientasWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="White">

        <!-- HEADER -->
        <Grid Background="#3B82F6" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Sistema Empresarial"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>

            <Button Content="Volver"
                    Click="Volver_Click"
                    Background="White"
                    Foreground="#3B82F6"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENIDO -->
        <StackPanel Margin="20,80,20,20" Spacing="15">

            <TextBlock Text="Gestión de Herramientas"
                       FontSize="22"
                       FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" Spacing="15">

                <Border Background="Gray" Padding="15" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Total herramientas"/>
                        <TextBlock Text="0" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="Gray" Padding="15" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Disponibles"/>
                        <TextBlock Text="0" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10">

                <TextBox x:Name="txtNombre" PlaceholderText="Nombre" Width="220"/>
                <TextBox x:Name="txtCantidad" PlaceholderText="Cantidad" Width="120"/>

                <Button Content="Agregar"
                        Click="Agregar_Click"
                        Background="#3B82F6"
                        Foreground="White"/>
            </StackPanel>

            <Border Background="Gray" CornerRadius="10" Padding="10">
                <ListView x:Name="lista" Height="300"/>
            </Border>

        </StackPanel>
    </Grid>
</Window>