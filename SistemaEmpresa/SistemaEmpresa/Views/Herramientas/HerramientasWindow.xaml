<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SistemaEmpresa.Views.Herramientas.HerramientasWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="20" Spacing="10">
        <TextBox x:Name="txtNombre" PlaceholderText="Nombre"/>
        <TextBox x:Name="txtCantidad" PlaceholderText="Cantidad"/>
        <Button Content="Agregar" Click="Agregar_Click"/>
        <ListView x:Name="lista"/>
    </StackPanel>
</Window>
